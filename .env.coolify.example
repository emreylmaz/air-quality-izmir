# Coolify production env variable isimleri — TEMPLATE
# Gerçek değerler Coolify UI/API'de tutulur. Bu dosya sadece hangi key'lerin
# gerektiğini dokümante eder. Değer YAZMA.

# === Coolify Magic Variables (Coolify tarafından otomatik üretilir) ===
# SERVICE_PASSWORD_AIR_QUALITY_DB       # PostgreSQL root password
# SERVICE_USER_AIR_QUALITY_DB           # PostgreSQL root user
# SERVICE_URL_AIR_QUALITY_DB_5432       # FQDN:port
# SERVICE_FQDN_AIR_QUALITY_GRAFANA      # Grafana public FQDN
# SERVICE_PASSWORD_APP_WRITER           # App writer role password
# SERVICE_PASSWORD_APP_READER           # App reader role password
# SERVICE_PASSWORD_GRAFANA_RO           # Grafana read-only role password

# === Custom 3rd-party secrets (sync_secrets.py push ile set edilir) ===
OPENWEATHER_API_KEY=__set_via_sync_secrets__

# === Runtime config (provision.py config.yaml içinde tanımlı) ===
APP_ENV=production
LOG_LEVEL=INFO
DATABASE_URL=postgresql://${SERVICE_USER_AIR_QUALITY_DB}:${SERVICE_PASSWORD_AIR_QUALITY_DB}@air-quality-db:5432/postgres
KAFKA_BOOTSTRAP_SERVERS=__set_via_tailscale_tunnel_or_coolify_kafka__

# === CI/CD erişimi (GitHub Actions secrets) ===
# COOLIFY_API_TOKEN           # GitHub Secret — workflow'da ::add-mask:: ile kullan
# COOLIFY_BASE_URL            # GitHub Variable (public)

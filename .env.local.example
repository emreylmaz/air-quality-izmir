# =============================================================================
# .env.local.example — Local Docker Compose stack template
# =============================================================================
# Kullanim:
#   1) cp .env.local.example .env.local
#   2) Gercek degerleri ~/.config/air-quality/secrets.env'den (1Password / vault)
#      .env.local'e kopyala VEYA direnv ile yukle:
#        source_env_if_exists ~/.config/air-quality/secrets.env
#   3) make up
#
# Secret policy: bkz. .claude/CLAUDE.md > "Secret Management Policy"
# - .env.local GITIGNORED — asla commit edilmez
# - Bu dosya sadece placeholder/dummy degerler icerir, gercek secret YASAK
# - detect-secrets pre-commit hook'u .env.local.example'i zaten muaf tutar
#   (.pre-commit-config.yaml exclude listesinde)
# =============================================================================

# --- App Environment ---------------------------------------------------------
APP_ENV=local
LOG_LEVEL=INFO

# --- PostgreSQL --------------------------------------------------------------
# Container init icin (compose POSTGRES_* env'lerini Postgres image'ina verir)
POSTGRES_USER=app
POSTGRES_PASSWORD=local_dev_pw_change_me
POSTGRES_DB=air_quality
POSTGRES_PORT=5432

# Uygulama tarafi (ingestion + streamlit Settings.database_url okur)
# Container icinden: host=postgres, port=5432; host'tan: localhost:5432
DATABASE_URL=postgresql://app:local_dev_pw_change_me@postgres:5432/air_quality  # pragma: allowlist secret

# --- Kafka -------------------------------------------------------------------
# Container icinden: kafka:9092; host'tan: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=air-quality-raw
KAFKA_TOPIC_WEATHER=weather-raw
KAFKA_TOPIC_DLQ=air-quality-dlq

# --- OpenWeatherMap ----------------------------------------------------------
# GERCEK key'i ~/.config/air-quality/secrets.env'den al, buraya YAZMA
OPENWEATHER_API_KEY=replace_me_from_~/.config/air-quality/secrets.env
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# --- Ingestion Scheduler -----------------------------------------------------
# APScheduler cron interval (dakika)
INGESTION_INTERVAL_MINUTES=60

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=local_admin_change_me
GRAFANA_PORT=3000

# --- Streamlit ---------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501

# --- Spark -------------------------------------------------------------------
# Streaming job local submit edildiginde kullanilir (compose icinde Spark
# container'lari ayri config alir)
SPARK_MASTER=spark://localhost:7077
SPARK_CHECKPOINT_DIR=/opt/spark-checkpoints/air-quality

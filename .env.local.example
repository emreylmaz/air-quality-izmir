# Local dev — docker-compose.local.yml tarafından okunur
# Gerçek değerleri .env.local'e kopyala (gitignored) veya direnv kullan
# Bu dosya TEMPLATE — dummy/placeholder değerler içerir, ASLA gerçek secret yazma

POSTGRES_USER=app
POSTGRES_PASSWORD=local_dev_pw_change_me
POSTGRES_DB=air_quality
POSTGRES_PORT=5432

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=air-quality-raw
KAFKA_TOPIC_WEATHER=weather-raw
KAFKA_TOPIC_DLQ=air-quality-dlq

OPENWEATHER_API_KEY=get_from_openweathermap.org
OPENWEATHER_CITY_ID=311046
# İzmir koordinatları (çoklu istasyon config ayrı yerde)

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=local_dev_pw_change_me
GRAFANA_PORT=3000

STREAMLIT_SERVER_PORT=8501

APP_ENV=local
LOG_LEVEL=INFO

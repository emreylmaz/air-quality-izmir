{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(black:*)",
      "Bash(pre-commit:*)",
      "Bash(detect-secrets:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose restart:*)",
      "Bash(git log:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",
      "Bash(psql -c '\\d*':*)",
      "Bash(psql -c '\\l':*)",
      "Bash(psql -c '\\dt*':*)",
      "Bash(psql -c '\\dv*':*)",
      "Bash(psql -c '\\di*':*)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make up)",
      "Bash(make down)",
      "Bash(make coolify-plan)",
      "Bash(make coolify-status)",
      "Bash(python -m infra.coolify.provision plan:*)",
      "Bash(python -m infra.coolify.provision status:*)",
      "Bash(python -m infra.coolify.sync_secrets list:*)",
      "Bash(python -m pytest:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker network prune:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(kubectl:*)",
      "Bash(helm:*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DROP SCHEMA*)",
      "Bash(*TRUNCATE*)",
      "Bash(psql*-c*DROP*)",
      "Bash(psql*-c*TRUNCATE*)",
      "Bash(curl -X DELETE*coolify*)",
      "Bash(curl*--request DELETE*coolify*)",
      "Bash(python -m infra.coolify.provision destroy:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)"
    ]
  }
}
